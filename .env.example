# ─────────────────────────────────────────────────────────────────────────────
# WhatsApp AI CRM — Environment Variables
# Copy this file to .env and fill in values.
# AI provider keys and payment gateway keys are configured from the DASHBOARD,
# not here. Only infrastructure config lives in this file.
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
DOMAIN=crm.yourcompany.com

# First admin account (created on first seed, change from dashboard after)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=changeme123

# ─── Database ─────────────────────────────────────────────────────────────────
# Use pgbouncer URL for app services, direct URL for migrations
DATABASE_URL=postgresql://crm:changeme@pgbouncer:5432/wacrm
DIRECT_DATABASE_URL=postgresql://crm:changeme@postgres:5432/wacrm
DB_USER=crm
DB_PASSWORD=changeme
DB_NAME=wacrm

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption (for API keys stored in the database) ────────────────────────
# Generate: openssl rand -hex 32
# WARNING: If you change this after data is stored, all encrypted values break.
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── MinIO (media file storage) ───────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_minio_secret
MINIO_BUCKET=wacrm-media
MINIO_USE_SSL=false
# Public URL for serving media (via Traefik)
MINIO_PUBLIC_URL=https://crm.yourcompany.com/media

# ─── API Ports (internal, exposed via Traefik) ────────────────────────────────
API_PORT=3001
WA_PORT=3002
WORKER_PORT=3003
DASHBOARD_PORT=3000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
API_RATE_LIMIT_TTL_MS=60000
API_RATE_LIMIT_MAX=100

# ─── Sentry (optional error tracking) ────────────────────────────────────────
SENTRY_DSN=

# ─── Backup ──────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30

# ─────────────────────────────────────────────────────────────────────────────
# DO NOT add AI provider keys or payment gateway keys here.
# Configure them from the dashboard: Settings → AI Model / Settings → Payments
# They are stored encrypted in the database.
# ─────────────────────────────────────────────────────────────────────────────
