FROM node:20-alpine AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN apk update && apk upgrade && \
    apk add --no-cache libc6-compat && \
    corepack enable && corepack prepare pnpm@10.33.0 --activate

FROM base AS builder
RUN apk add --no-cache python3 make g++
WORKDIR /app
COPY . .
RUN pnpm dlx turbo@latest prune --scope=@wacrm/whatsapp --docker

FROM base AS installer
RUN apk add --no-cache python3 make g++
WORKDIR /app

COPY --from=builder /app/out/json/ .
COPY --from=builder /app/out/pnpm-lock.yaml ./pnpm-lock.yaml
RUN pnpm install --frozen-lockfile

COPY --from=builder /app/out/full/ .
COPY turbo.json turbo.json
COPY tsconfig.base.json tsconfig.base.json
RUN pnpm turbo build --filter=@wacrm/whatsapp

FROM node:20-alpine AS runner
RUN apk update && apk upgrade && \
    apk add --no-cache libc6-compat
WORKDIR /app

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nestjs

COPY --from=installer --chown=nestjs:nodejs /app/apps/whatsapp/dist ./dist
COPY --from=installer --chown=nestjs:nodejs /app/node_modules ./node_modules
COPY --from=installer --chown=nestjs:nodejs /app/packages ./packages

USER nestjs
CMD ["node", "dist/apps/whatsapp/src/main.js"]
