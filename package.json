{
  "name": "agentic-crm",
  "version": "1.5.1",
  "private": true,
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "dev:api": "turbo dev --filter=api",
    "dev:whatsapp": "turbo dev --filter=whatsapp",
    "dev:worker": "turbo dev --filter=worker",
    "dev:dashboard": "turbo dev --filter=dashboard",
    "db:migrate": "dotenv -e .env -- turbo db:migrate --filter=@wacrm/database",
    "db:seed": "dotenv -e .env -- turbo db:seed --filter=@wacrm/database",
    "db:studio": "dotenv -e .env -- turbo db:studio --filter=@wacrm/database",
    "db:generate": "turbo db:generate --filter=@wacrm/database",
    "db:push": "dotenv -e .env -- turbo db:push --filter=@wacrm/database"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.5",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "sharp",
      "protobufjs",
      "unrs-resolver"
    ],
    "overrides": {
      "lodash": "^4.18.0",
      "multer": "^2.1.1",
      "picomatch": "^4.0.4",
      "glob": "^11.0.0",
      "js-yaml": "^4.1.1",
      "ajv@^6": "6.14.0",
      "ajv@^8": "8.18.0",
      "tmp": "^0.2.5",
      "music-metadata": "^11.12.3",
      "file-type": "^21.3.2",
      "webpack": "^5.104.0",
      "path-to-regexp": "^8.4.2",
      "@hono/node-server": "^1.19.13"
    }
  }
}
