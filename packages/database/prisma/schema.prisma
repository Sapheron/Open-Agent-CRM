model Template {
  id             String           @id @default(cuid())
  companyId      String
  name           String
  type           TemplateType     @default(TEXT)
  status         TemplateStatus   @default(DRAFT)
  category       TemplateCategory @default(GENERAL)
  body           String           @db.Text
  variables      Json             @default("{}")
  mediaUrl       String?
  language       String           @default("en")
  tags           String[]         @default([])

  // Usage tracking
  useCount       Int              @default(0)
  lastUsedAt     DateTime?
  sentCount      Int              @default(0)
  deliveredCount Int              @default(0)
  failedCount    Int              @default(0)

  // Conversions
  conversionCount Int             @default(0)

  // A/B testing
  variantOf      String?
  variantName    String?

  createdById    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activities     TemplateActivity[]
  createdBy      User?            @relation("TemplateCreator", fields: [createdById], references: [id])
  variants       Template[]       @relation("TemplateVariants")
  parent         Template?        @relation("TemplateVariants", fields: [variantOf], references: [id])
  usedInSteps    SequenceStep[]

  @@unique([companyId, name])
  @@index([companyId, status])
  @@index([companyId, category])
  @@index([companyId, useCount])
  @@index([variantOf])
}

model TemplateActivity {
  id         String                @id @default(cuid())
  templateId String
  companyId  String
  type       TemplateActivityType
  actorType  String
  actorId    String?
