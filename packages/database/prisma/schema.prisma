model Invoice {
  id              String        @id @default(cuid())
  companyId       String
  contactId       String?
  dealId          String?
  /// Link to the source Quote when converted via createFromQuote.
  fromQuoteId     String?
  invoiceNumber   String
  /// Public URL token for customer view. 32-char hex, unique, generated on create.
  publicToken     String        @unique
  status          InvoiceStatus @default(DRAFT)
  title           String?
  description     String?

  /// All money is in minor units (paise/cents).
  subtotal        Int           @default(0)
  tax             Int           @default(0)
  /// Tax percent in bps 0-10000 (e.g. 1800 = 18.00%).
  taxBps          Int           @default(0)
  discount        Int           @default(0)
  total           Int           @default(0)
  /// Running total of recorded payments. When amountPaid >= total, status
  /// auto-transitions to PAID. When 0 < amountPaid < total, PARTIALLY_PAID.
  amountPaid      Int           @default(0)

  currency        String        @default("INR")
  dueDate         DateTime?
  sentAt          DateTime?
  viewedAt        DateTime?
  paidAt          DateTime?
  cancelledAt     DateTime?
  voidedAt        DateTime?
  cancelReason    String?

  notes           String?
  terms           String?
  tags            String[]      @default([])
  createdByUserId String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  lineItems  InvoiceLineItem[]
  activities InvoiceActivity[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, contactId])
  @@index([companyId, dealId])
  @@index([companyId, dueDate])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  /// Stable ordering key within an invoice (1-based, dense).
  sortOrder   Int     @default(0)
  name        String
  description String?
  quantity    Int     @default(1)
  unitPrice   Int     @default(0)
  /// Per-line discount bps 0-10000.
  discountBps Int     @default(0)
  total       Int     @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([invoiceId, sortOrder])
}

model InvoiceActivity {
  id        String              @id @default(cuid())
  invoiceId String
  companyId String
  type      InvoiceActivityType
  actorType String              // "user" | "ai" | "system" | "worker" | "public"
  actorId   String?
  title     String
  body      String?
  metadata  Json                @default("{}")
  createdAt DateTime            @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, createdAt])
  @@index([companyId, type, createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 4: MARKETING
// ═══════════════════════════════════════════════════════════════════════════════

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  PAUSED
  COMPLETED
  CANCELLED
  FAILED
}

enum CampaignChannel {
  WHATSAPP
  EMAIL
  SMS
}

/// How the campaign actually delivers messages.
/// DIRECT    — campaign owns its own rate-limited sender
/// BROADCAST — dispatches via an existing Broadcast on launch
/// SEQUENCE  — enrolls the resolved audience into a Sequence
enum CampaignSendMode {
  DIRECT
  BROADCAST
  SEQUENCE
}

enum CampaignRecipientStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  READ
  REPLIED
  FAILED
  SKIPPED
  OPTED_OUT
}

enum CampaignActivityType {
  CREATED
  STATUS_CHANGED
  SCHEDULED
  LAUNCHED
  PAUSED
  RESUMED
  CANCELLED
  COMPLETED
  AUDIENCE_UPDATED
  RECIPIENTS_ADDED
  RECIPIENTS_REMOVED
  NOTE_ADDED
  FIELD_UPDATED
  BROADCAST_DISPATCHED
  SEQUENCE_ENROLLED
  RECIPIENT_SENT
  RECIPIENT_FAILED
  RECIPIENT_DELIVERED
  RECIPIENT_READ
  RECIPIENT_REPLIED
  ERROR
}

model Campaign {
  id              String           @id @default(cuid())
  companyId       String
  name            String
  description     String?
  channel         CampaignChannel  @default(WHATSAPP)
  sendMode        CampaignSendMode @default(DIRECT)
  status          CampaignStatus   @default(DRAFT)

  /// Template used to render per-recipient bodies (DIRECT mode only).
  templateId      String?
  /// Populated on launch when sendMode = BROADCAST.
  broadcastId     String?
  /// Populated on launch when sendMode = SEQUENCE.
  sequenceId      String?

  startAt         DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  pausedAt        DateTime?
  cancelledAt     DateTime?

  /// Audience filter — tags are AND-joined against contact.tags.
  audienceTags          String[] @default([])
  /// Explicit adds, merged with tag filter.
  audienceContactIds    String[] @default([])
  /// "skip" (default) or "fail" — what to do for opted-out contacts that match.
  audienceOptOutBehavior String  @default("skip")

  /// Rate limit applied by the DIRECT-mode send processor (ms between sends).
  throttleMs      Int              @default(2000)

  /// Analytics snapshots — maintained by the worker.
  totalRecipients  Int              @default(0)
  sentCount        Int              @default(0)
  deliveredCount   Int              @default(0)
  readCount        Int              @default(0)
  repliedCount     Int              @default(0)
  failedCount      Int              @default(0)
  optedOutCount    Int              @default(0)

  /// Meta
  tags             String[]         @default([])
  priority         String           @default("MEDIUM") // LOW|MEDIUM|HIGH|URGENT
  budget           Int?
  notes            String?
  errorMessage     String?
  createdByUserId  String?

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  recipients       CampaignRecipient[]
  activities       CampaignActivity[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, startAt])
  @@index([startAt, status])
}

model CampaignRecipient {
  id                String                  @id @default(cuid())
  campaignId        String
  companyId         String
  contactId         String
  status            CampaignRecipientStatus @default(PENDING)
  queuedAt          DateTime?
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  repliedAt         DateTime?
  failedAt          DateTime?
  errorReason       String?
  /// Linked Message id once the outbound message is created.
  messageId         String?
  /// Rendered, personalized body for DIRECT sends. Stored so retries do not
  /// re-render and the audit shows the exact text sent.
  renderedText      String?
  metadata          Json                    @default("{}")

  campaign          Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([campaignId, status])
  @@index([companyId, status])
  @@index([contactId])
}

model CampaignActivity {
  id          String               @id @default(cuid())
  campaignId  String
  companyId   String
  type        CampaignActivityType
  actorType   String               // "user" | "ai" | "system" | "worker"
  actorId     String?
  title       String
  body        String?
  metadata    Json                 @default("{}")
  createdAt   DateTime             @default(now())

  campaign    Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
  @@index([companyId, type, createdAt])
}

enum FormStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum FormSubmissionStatus {
  RECEIVED
  PROCESSED
  SPAM
  CONVERTED
  ARCHIVED
}

enum FormActivityType {
  CREATED
  RENAMED
  PUBLISHED
  UNPUBLISHED
  ARCHIVED
  RESTORED
  FIELD_UPDATED
  FIELD_ADDED
  FIELD_REMOVED
  FIELDS_REORDERED
  AUTO_ACTIONS_UPDATED
  NOTE_ADDED
  SUBMISSION_RECEIVED
  SUBMISSION_CONVERTED
  SUBMISSION_MARKED_SPAM
  WEBHOOK_ROTATED
  DUPLICATED
  ERROR
}

model Form {
  id              String     @id @default(cuid())
  companyId       String
  name            String
  slug            String     // URL-safe identifier, unique per company
  description     String?
  /// JSON array of FormField objects (see apps/api/src/modules/forms/forms.types.ts)
  fields          Json       @default("[]")
  status          FormStatus @default(DRAFT)
  publishedAt     DateTime?

  // Public rendering
  isPublic        Boolean    @default(false)
  requireCaptcha  Boolean    @default(false)
  rateLimitPerHour Int       @default(30)

  // Auto-actions fired on every submission (all opt-in)
  autoCreateLead       Boolean   @default(false)
  autoLeadSource       String?   @default("FORM")
  autoLeadTitle        String?   // may contain {{var}} tokens from field keys
  autoEnrollSequenceId String?
  autoAssignUserId     String?
  autoTagContact       String[]  @default([])

  // Optional forward-to-external-URL (e.g. Zapier catch hook)
  webhookForwardUrl       String?
  /// Encrypted with AES-256-GCM via @wacrm/shared:encrypt
  webhookForwardSecret    String?

  // Meta
  priority        String     @default("MEDIUM")
  tags            String[]   @default([])
  notes           String?

  // Analytics counters maintained by the service
  submitCount     Int        @default(0)
  convertedCount  Int        @default(0)
  spamCount       Int        @default(0)

  createdByUserId String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  submissions FormSubmission[]
  activities  FormActivity[]

  @@unique([companyId, name])
  @@unique([companyId, slug])
  @@index([companyId])
  @@index([companyId, status])
}

model FormSubmission {
  id                   String               @id @default(cuid())
  formId               String
  companyId            String
  /// The raw key→value map of what the user filled in.
  data                 Json                 @default("{}")
  status               FormSubmissionStatus @default(RECEIVED)
  contactId            String?
  leadId               String?
  sequenceEnrollmentId String?
  utmSource            String?
  utmMedium            String?
  utmCampaign          String?
  referrer             String?
  userAgent            String?
  ipAddress            String?
  errorReason          String?
  processedAt          DateTime?
  createdAt            DateTime             @default(now())

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([formId, status])
  @@index([companyId])
  @@index([companyId, status])
}

model FormActivity {
  id         String           @id @default(cuid())
  formId     String
  companyId  String
  type       FormActivityType
  actorType  String           // "user" | "ai" | "system" | "worker" | "public"
  actorId    String?
  title      String
  body       String?
  metadata   Json             @default("{}")
  createdAt  DateTime         @default(now())

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, createdAt])
  @@index([companyId, type, createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 5: AUTOMATION
