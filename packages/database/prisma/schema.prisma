generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  AGENT
}

enum ConversationStatus {
  OPEN
  AI_HANDLING
  WAITING_HUMAN
  HUMAN_HANDLING
  RESOLVED
  CLOSED
  SPAM
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  LOCATION
  CONTACT
  TEMPLATE
  INTERACTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATING
  WON
  LOST
  DISQUALIFIED
}

enum DealStage {
  LEAD_IN
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
}

enum AiProvider {
  GEMINI
  OPENAI
  ANTHROPIC
  GROQ
  DEEPSEEK
  XAI
  MISTRAL
  TOGETHER
  MOONSHOT
  GLM
  QWEN
  STEPFUN
  OLLAMA
  OPENROUTER
  CUSTOM
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
  CASHFREE
  PHONEPE
  PAYU
  NONE
}

enum WaAccountStatus {
  DISCONNECTED
  QR_PENDING
  CONNECTING
  CONNECTED
  BANNED
  ERROR
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  AI_TOOL_CALL
  AI_REPLY
  PAYMENT_CREATED
  PAYMENT_RECEIVED
  WA_SESSION_START
  WA_SESSION_END
  USER_LOGIN
  USER_LOGOUT
  SETTINGS_CHANGE
}

// ─── COMPANY ──────────────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  email     String?
  phone     String?
  website   String?
  logoUrl   String?
  timezone  String   @default("UTC")
  isActive  Boolean  @default(true)
  setupDone Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  whatsappAccounts WhatsAppAccount[]
  contacts         Contact[]
  conversations    Conversation[]
  leads            Lead[]
  deals            Deal[]
  tasks            Task[]
  payments         Payment[]
  broadcasts       Broadcast[]
  auditLogs        AuditLog[]
  aiConfig         AiConfig?
  paymentConfig    PaymentConfig?
  webhookEndpoints WebhookEndpoint[]

  @@index([slug])
  @@index([isActive])
}

// ─── USER ─────────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  companyId        String
  email            String
  passwordHash     String
  firstName        String
  lastName         String
  avatarUrl        String?
  role             UserRole  @default(AGENT)
  isActive         Boolean   @default(true)
  refreshTokenHash String?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedConvs Conversation[] @relation("AssignedAgent")
  assignedLeads Lead[]         @relation("AssignedAgent")
  assignedDeals Deal[]         @relation("AssignedAgent")
  assignedTasks Task[]         @relation("AssignedAgent")
  createdTasks  Task[]         @relation("CreatedBy")
  auditLogs     AuditLog[]

  @@unique([companyId, email])
  @@index([companyId])
  @@index([email])
}

// ─── WHATSAPP ACCOUNT ─────────────────────────────────────────────────────────

model WhatsAppAccount {
  id                String          @id @default(cuid())
  companyId         String
  phoneNumber       String
  displayName       String?
  status            WaAccountStatus @default(DISCONNECTED)
  provider          String          @default("baileys")
  accessTokenEnc    String?
  phoneNumberId     String?
  sessionDataEnc    Bytes?
  qrCode            String?
  warmupStage       Int             @default(0)
  warmupStartedAt   DateTime?
  dailyMessageLimit Int             @default(50)
  messagesSentToday Int             @default(0)
  lastResetAt       DateTime?
  consecutiveErrors Int             @default(0)
  lastErrorAt       DateTime?
  lastConnectedAt   DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  messages      Message[]

  @@unique([companyId, phoneNumber])
  @@index([companyId])
  @@index([status])
}

// ─── CONTACT ──────────────────────────────────────────────────────────────────

model Contact {
  id             String    @id @default(cuid())
  companyId      String
  phoneNumber    String
  displayName    String?
  firstName      String?
  lastName       String?
  email          String?
  avatarUrl      String?
  tags           String[]
  customFields   Json      @default("{}")
  notes          String?
  lifecycleStage String    @default("SUBSCRIBER")
  score          Int       @default(0)
  companyName    String?
  jobTitle       String?
  address        String?
  socialLinks    Json      @default("{}")
  referredById   String?
  isBlocked      Boolean   @default(false)
  optedOut       Boolean   @default(false)
  optedOutAt     DateTime?
  lastSeenAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  referredBy     Contact?       @relation("ContactReferrals", fields: [referredById], references: [id])
  referrals      Contact[]      @relation("ContactReferrals")
  conversations  Conversation[]
  leads          Lead[]
  deals          Deal[]
  tasks          Task[]
  payments       Payment[]
  contactNotes   ContactNote[]

  @@unique([companyId, phoneNumber])
  @@index([companyId])
  @@index([phoneNumber])
  @@index([companyId, deletedAt])
  @@index([tags])
  @@index([companyId, lifecycleStage])
  @@index([companyId, score])
}

// ─── CONVERSATION ─────────────────────────────────────────────────────────────

model Conversation {
  id                String             @id @default(cuid())
  companyId         String
  contactId         String
  whatsappAccountId String
  assignedAgentId   String?
  status            ConversationStatus @default(OPEN)
  aiEnabled         Boolean            @default(true)
  unreadCount       Int                @default(0)
  lastMessageAt     DateTime?
  lastMessageText   String?
  resolvedAt        DateTime?
  metadata          Json               @default("{}")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact         Contact         @relation(fields: [contactId], references: [id])
  whatsappAccount WhatsAppAccount @relation(fields: [whatsappAccountId], references: [id])
  assignedAgent   User?           @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  messages        Message[]
  aiContextCache  AiContextCache?

  @@index([companyId])
  @@index([contactId])
  @@index([status])
  @@index([companyId, status])
  @@index([lastMessageAt])
}

// ─── MESSAGE ──────────────────────────────────────────────────────────────────

model Message {
  id                String           @id @default(cuid())
  companyId         String
  conversationId    String
  whatsappAccountId String
  whatsappMessageId String?
  idempotencyKey    String?          @unique
  direction         MessageDirection
  type              MessageType      @default(TEXT)
  status            MessageStatus    @default(PENDING)
  body              String?
  mediaUrl          String?
  mediaType         String?
  mediaSizeBytes    Int?
  mediaCaption      String?
  latitude          Float?
  longitude         Float?
  replyToMessageId  String?
  isAiGenerated     Boolean          @default(false)
  aiProvider        String?
  aiModel           String?
  aiTokensUsed      Int?
  aiLatencyMs       Int?
  errorMessage      String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  failedAt          DateTime?
  createdAt         DateTime         @default(now())

  conversation    Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsAppAccount @relation(fields: [whatsappAccountId], references: [id])
  replyTo         Message?        @relation("ReplyThread", fields: [replyToMessageId], references: [id])
  replies         Message[]       @relation("ReplyThread")

  @@index([conversationId])
  @@index([whatsappMessageId])
  @@index([idempotencyKey])
  @@index([companyId, createdAt])
  @@index([direction, status])
}

// ─── LEAD ─────────────────────────────────────────────────────────────────────

model Lead {
  id              String     @id @default(cuid())
  companyId       String
  contactId       String
  assignedAgentId String?
  title           String
  status          LeadStatus @default(NEW)
  source          String?
  score           Int        @default(0)
  estimatedValue  Float?
  currency        String     @default("INR")
  notes           String?
  customFields    Json       @default("{}")
  lostReason      String?
  wonAt           DateTime?
  lostAt          DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact       Contact @relation(fields: [contactId], references: [id])
  assignedAgent User?   @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  deals         Deal[]

  @@index([companyId])
  @@index([contactId])
  @@index([status])
  @@index([companyId, status])
}

// ─── DEAL ─────────────────────────────────────────────────────────────────────

model Deal {
  id              String    @id @default(cuid())
  companyId       String
  contactId       String
  leadId          String?
  assignedAgentId String?
  title           String
  stage           DealStage @default(LEAD_IN)
  value           Float
  currency        String    @default("INR")
  probability     Int       @default(20)
  expectedCloseAt DateTime?
  wonAt           DateTime?
  lostAt          DateTime?
  lostReason      String?
  notes           String?
  customFields    Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact       Contact   @relation(fields: [contactId], references: [id])
  lead          Lead?     @relation(fields: [leadId], references: [id])
  assignedAgent User?     @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  payments      Payment[]
  tasks         Task[]

  @@index([companyId])
  @@index([contactId])
  @@index([stage])
  @@index([companyId, stage])
}

// ─── TASK ─────────────────────────────────────────────────────────────────────

model Task {
  id              String       @id @default(cuid())
  companyId       String
  contactId       String?
  dealId          String?
  assignedAgentId String?
  createdById     String?
  title           String
  description     String?
  status          TaskStatus   @default(TODO)
  priority        TaskPriority @default(MEDIUM)
  dueAt           DateTime?
  completedAt     DateTime?
  reminderSentAt  DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact       Contact? @relation(fields: [contactId], references: [id])
  deal          Deal?    @relation(fields: [dealId], references: [id])
  assignedAgent User?    @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  createdBy     User?    @relation("CreatedBy", fields: [createdById], references: [id])

  @@index([companyId])
  @@index([assignedAgentId])
  @@index([dueAt])
  @@index([status])
}

// ─── AI CONFIG ────────────────────────────────────────────────────────────────

model AiConfig {
  id                 String     @id @default(cuid())
  companyId          String     @unique
  provider           AiProvider @default(GEMINI)
  model              String     @default("gemini-2.0-flash")
  apiKeyEncrypted    String?
  baseUrl            String?
  systemPrompt       String     @default("You are a helpful sales assistant. Help the customer and capture their information.")
  tone               String     @default("professional")
  maxTokens          Int        @default(1024)
  temperature        Float      @default(0.7)
  autoReplyEnabled   Boolean    @default(true)
  toolCallingEnabled Boolean    @default(true)
  testStatus         String?
  testError          String?
  updatedAt          DateTime   @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AiContextCache {
  id             String   @id @default(cuid())
  conversationId String   @unique
  messages       Json
  tokenCount     Int
  pruneCount     Int      @default(0)
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ─── PAYMENT ──────────────────────────────────────────────────────────────────

model PaymentConfig {
  id              String          @id @default(cuid())
  companyId       String          @unique
  provider        PaymentProvider @default(NONE)
  keyEncrypted    String?
  secretEncrypted String?
  webhookSecret   String?
  currency        String          @default("INR")
  testMode        Boolean         @default(true)
  updatedAt       DateTime        @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Payment {
  id             String          @id @default(cuid())
  companyId      String
  contactId      String?
  dealId         String?
  provider       PaymentProvider
  externalId     String?
  linkUrl        String?
  amount         Int
  currency       String          @default("INR")
  description    String?
  status         PaymentStatus   @default(PENDING)
  paidAt         DateTime?
  refundedAt     DateTime?
  webhookPayload Json?
  idempotencyKey String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id])
  deal    Deal?    @relation(fields: [dealId], references: [id])

  @@index([companyId])
  @@index([externalId])
  @@index([status])
  @@index([idempotencyKey])
}

// ─── BROADCAST ────────────────────────────────────────────────────────────────

model Broadcast {
  id               String    @id @default(cuid())
  companyId        String
  name             String
  message          String
  mediaUrl         String?
  targetTags       String[]
  targetContactIds String[]
  scheduledAt      DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  totalCount       Int       @default(0)
  sentCount        Int       @default(0)
  failedCount      Int       @default(0)
  createdAt        DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([scheduledAt])
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  companyId  String
  userId     String?
  action     AuditAction
  entityType String?
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─── WEBHOOK ENDPOINT ─────────────────────────────────────────────────────────

model WebhookEndpoint {
  id        String   @id @default(cuid())
  companyId String
  url       String
  secret    String
  events    String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ─── CONTACT NOTE ────────────────────────────────────────────────────────────

model ContactNote {
  id        String   @id @default(cuid())
  companyId String
  contactId String
  authorId  String?
  content   String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([companyId])
}

// ─── TAG ─────────────────────────────────────────────────────────────────────

model Tag {
  id          String  @id @default(cuid())
  companyId   String
  name        String
  color       String  @default("#8b5cf6")
  description String?

  @@unique([companyId, name])
  @@index([companyId])
}

// ─── SEGMENT ─────────────────────────────────────────────────────────────────

model Segment {
  id        String   @id @default(cuid())
  companyId String
  name      String
  type      String   @default("DYNAMIC") // DYNAMIC or STATIC
  filters   Json     @default("{}") // For DYNAMIC: filter rules
  contactIds String[] // For STATIC: manually added contacts
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

// ─── CUSTOM FIELD DEFINITION ─────────────────────────────────────────────────

model CustomFieldDefinition {
  id         String   @id @default(cuid())
  companyId  String
  entityType String   // "contact", "lead", "deal"
  fieldName  String
  fieldType  String   // "text", "number", "date", "select", "multiselect"
  options    String[] // For select/multiselect
  required   Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@unique([companyId, entityType, fieldName])
  @@index([companyId, entityType])
}

// ─── NOTIFICATION ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  companyId String
  userId    String?
  title     String
  body      String
  type      String   @default("info") // info, success, warning, error
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([companyId, userId, read])
  @@index([companyId, createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 2: COMMUNICATION
// ═══════════════════════════════════════════════════════════════════════════════

model Template {
  id        String   @id @default(cuid())
  companyId String
  name      String
  category  String   @default("general") // greeting, follow-up, payment, support
  body      String
  variables String[] // e.g. ["name", "amount"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId, category])
}

model CannedResponse {
  id        String @id @default(cuid())
  companyId String
  shortcut  String // e.g. "/hello"
  body      String

  @@unique([companyId, shortcut])
  @@index([companyId])
}

model Sequence {
  id        String   @id @default(cuid())
  companyId String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps       SequenceStep[]
  enrollments SequenceEnrollment[]

  @@unique([companyId, name])
  @@index([companyId])
}

model SequenceStep {
  id         String @id @default(cuid())
  sequenceId String
  sortOrder  Int
  delayHours Int    @default(24)
  action     String @default("send_message") // send_message, send_email, wait
  message    String?
  templateId String?

  sequence Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
}

model SequenceEnrollment {
  id         String    @id @default(cuid())
  sequenceId String
  contactId  String
  companyId  String
  currentStep Int      @default(0)
  status     String    @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED, STOPPED
  nextRunAt  DateTime?
  enrolledAt DateTime  @default(now())
  completedAt DateTime?

  sequence Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([sequenceId, status])
  @@index([nextRunAt])
}

model CallLog {
  id        String   @id @default(cuid())
  companyId String
  contactId String
  agentId   String?
  duration  Int?     // seconds
  outcome   String?  // connected, no_answer, voicemail, callback
  notes     String?
  createdAt DateTime @default(now())

  @@index([companyId, contactId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 3: SALES PIPELINE
// ═══════════════════════════════════════════════════════════════════════════════

model Pipeline {
  id        String   @id @default(cuid())
  companyId String
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  stages PipelineStage[]

  @@unique([companyId, name])
  @@index([companyId])
}

model PipelineStage {
  id         String @id @default(cuid())
  pipelineId String
  name       String
  color      String @default("#8b5cf6")
  sortOrder  Int
  probability Int   @default(0) // 0-100

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId])
}

model Product {
  id          String  @id @default(cuid())
  companyId   String
  name        String
  description String?
  price       Int     @default(0) // in smallest unit (paise/cents)
  currency    String  @default("INR")
  sku         String?
  isActive    Boolean @default(true)

  @@unique([companyId, sku])
  @@index([companyId])
}

model Quote {
  id          String      @id @default(cuid())
  companyId   String
  contactId   String?
  dealId      String?
  quoteNumber String
  status      String      @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED
  subtotal    Int         @default(0)
  tax         Int         @default(0)
  discount    Int         @default(0)
  total       Int         @default(0)
  currency    String      @default("INR")
  validUntil  DateTime?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  lineItems QuoteLineItem[]

  @@index([companyId])
}

model QuoteLineItem {
  id        String @id @default(cuid())
  quoteId   String
  productId String?
  name      String
  quantity  Int    @default(1)
  unitPrice Int    @default(0)
  total     Int    @default(0)

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model Invoice {
  id            String   @id @default(cuid())
  companyId     String
  contactId     String?
  dealId        String?
  invoiceNumber String
  status        String   @default("UNPAID") // UNPAID, PAID, OVERDUE, CANCELLED
  subtotal      Int      @default(0)
  tax           Int      @default(0)
  total         Int      @default(0)
  currency      String   @default("INR")
  dueDate       DateTime?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime @default(now())

  lineItems InvoiceLineItem[]

  @@index([companyId])
  @@index([companyId, status])
}

model InvoiceLineItem {
  id        String @id @default(cuid())
  invoiceId String
  name      String
  quantity  Int    @default(1)
  unitPrice Int    @default(0)
  total     Int    @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 4: MARKETING
// ═══════════════════════════════════════════════════════════════════════════════

model Campaign {
  id          String    @id @default(cuid())
  companyId   String
  name        String
  channel     String    @default("whatsapp") // whatsapp, email, sms
  status      String    @default("DRAFT") // DRAFT, ACTIVE, PAUSED, COMPLETED
  segmentId   String?
  budget      Int?
  startDate   DateTime?
  endDate     DateTime?
  sentCount   Int       @default(0)
  replyCount  Int       @default(0)
  convertedCount Int    @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([companyId, status])
}

model Form {
  id        String   @id @default(cuid())
  companyId String
  name      String
  fields    Json     @default("[]") // [{name, type, required, label}]
  isActive  Boolean  @default(true)
  submitCount Int    @default(0)
  createdAt DateTime @default(now())

  submissions FormSubmission[]

  @@unique([companyId, name])
  @@index([companyId])
}

model FormSubmission {
  id        String   @id @default(cuid())
  formId    String
  companyId String
  data      Json     @default("{}")
  contactId String?
  leadId    String?
  utmSource String?
  utmMedium String?
  utmCampaign String?
  ipAddress String?
  createdAt DateTime @default(now())

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([companyId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 5: AUTOMATION
// ═══════════════════════════════════════════════════════════════════════════════

model Workflow {
  id        String   @id @default(cuid())
  companyId String
  name      String
  isActive  Boolean  @default(false)
  trigger   Json     @default("{}") // {type: "contact_created", conditions: {...}}
  steps     Json     @default("[]") // [{type: "action", action: "send_message", config: {...}}]
  runCount  Int      @default(0)
  lastRunAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  executions WorkflowExecution[]

  @@unique([companyId, name])
  @@index([companyId, isActive])
}

model WorkflowExecution {
  id         String   @id @default(cuid())
  workflowId String
  companyId  String
  contactId  String?
  status     String   @default("RUNNING") // RUNNING, COMPLETED, FAILED
  steps      Json     @default("[]") // [{step, status, result, timestamp}]
  error      String?
  startedAt  DateTime @default(now())
  completedAt DateTime?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([companyId, status])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 7: CUSTOMER SUPPORT
// ═══════════════════════════════════════════════════════════════════════════════

model Ticket {
  id           String    @id @default(cuid())
  companyId    String
  contactId    String?
  assignedToId String?
  title        String
  description  String?
  status       String    @default("OPEN") // OPEN, IN_PROGRESS, WAITING, RESOLVED, CLOSED
  priority     String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  category     String?   // bug, feature, billing, general
  source       String    @default("whatsapp") // whatsapp, email, web, manual
  firstResponseAt DateTime?
  resolvedAt   DateTime?
  closedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  comments TicketComment[]

  @@index([companyId, status])
  @@index([companyId, assignedToId])
  @@index([companyId, priority])
}

model TicketComment {
  id         String   @id @default(cuid())
  ticketId   String
  authorId   String?
  content    String
  isInternal Boolean  @default(false) // internal notes not visible to customer
  createdAt  DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model KnowledgeBaseArticle {
  id        String   @id @default(cuid())
  companyId String
  title     String
  content   String
  category  String?
  isPublic  Boolean  @default(true)
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, category])
}

model SlaPolicy {
  id                  String @id @default(cuid())
  companyId           String
  name                String
  firstResponseMins   Int    @default(60)
  resolutionMins      Int    @default(480)
  priority            String @default("MEDIUM")
  isActive            Boolean @default(true)

  @@unique([companyId, name])
  @@index([companyId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 8: REPORTING
// ═══════════════════════════════════════════════════════════════════════════════

model CustomReport {
  id        String   @id @default(cuid())
  companyId String
  name      String
  entity    String   // contacts, leads, deals, tickets, payments
  filters   Json     @default("{}")
  groupBy   String?
  columns   String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model ScheduledReport {
  id        String   @id @default(cuid())
  companyId String
  reportId  String
  frequency String   @default("weekly") // daily, weekly, monthly
  recipients String[] // email addresses
  lastSentAt DateTime?
  nextRunAt  DateTime?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([companyId])
  @@index([nextRunAt, isActive])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 9: INTEGRATIONS
// ═══════════════════════════════════════════════════════════════════════════════

model Integration {
  id        String   @id @default(cuid())
  companyId String
  type      String   // google_calendar, outlook, slack, discord, telegram, instagram
  config    Json     @default("{}") // encrypted config
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, type])
  @@index([companyId])
}

model CalendarEvent {
  id          String    @id @default(cuid())
  companyId   String
  contactId   String?
  dealId      String?
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  location    String?
  externalId  String?
  createdAt   DateTime  @default(now())

  @@index([companyId])
  @@index([companyId, startAt])
}

model ActivityLog {
  id         String   @id @default(cuid())
  companyId  String
  userId     String?
  contactId  String?
  entityType String   // contact, lead, deal, ticket, task
  entityId   String
  action     String   // created, updated, status_changed, assigned, etc.
  details    Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([companyId, entityType, entityId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 10: DOCUMENTS & SECURITY
// ═══════════════════════════════════════════════════════════════════════════════

model Document {
  id        String   @id @default(cuid())
  companyId String
  contactId String?
  dealId    String?
  name      String
  type      String   // proposal, contract, invoice_pdf, other
  fileUrl   String
  fileSize  Int?
  mimeType  String?
  createdAt DateTime @default(now())

  signatures DocumentSignature[]

  @@index([companyId])
  @@index([companyId, contactId])
}

model DocumentSignature {
  id         String    @id @default(cuid())
  documentId String
  signerName String
  signerEmail String?
  status     String    @default("PENDING") // PENDING, SIGNED, DECLINED
  signedAt   DateTime?
  createdAt  DateTime  @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model ApiKey {
  id        String   @id @default(cuid())
  companyId String
  name      String
  keyHash   String   @unique // hashed API key
  prefix    String   // first 8 chars for display
  scopes    String[] // ["contacts:read", "contacts:write", etc.]
  lastUsedAt DateTime?
  expiresAt DateTime?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([keyHash])
}

// ═══════════════════════════════════════════════════════════════════════════════
// AI CHAT CONVERSATIONS (persistent)
// ═══════════════════════════════════════════════════════════════════════════════

model ChatConversation {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  title     String   @default("New Chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@index([companyId, userId, updatedAt])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // user, assistant
  content        String
  toolCalls      Json?    // [{tool, args, result}]
  provider       String?
  model          String?
  latencyMs      Int?
  createdAt      DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════════
// AI MEMORY (knowledge base for AI context)
// ═══════════════════════════════════════════════════════════════════════════════

model AiMemory {
  id        String   @id @default(cuid())
  companyId String
  title     String
  content   String   // The knowledge/fact/instruction
  category  String   @default("general") // general, product, policy, faq, instruction
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, isActive])
  @@index([companyId, category])
}
