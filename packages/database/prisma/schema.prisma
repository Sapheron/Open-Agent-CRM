}

model Sequence {
  id                String          @id @default(cuid())
  companyId         String
  name              String
  description       String?         @db.Text
  status            SequenceStatus @default(DRAFT)

  // Analytics
  useCount          Int             @default(0)
  completionCount   Int             @default(0)
  avgCompletionTime Float?
  lastUsedAt        DateTime?

  // Organization
  tags              String[]        @default([])
  createdById       String?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  company           Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  steps             SequenceStep[]
  enrollments       SequenceEnrollment[]
  activities        SequenceActivity[]
  createdBy         User?            @relation("SequenceCreator", fields: [createdById], references: [id])

  @@unique([companyId, name])
  @@index([companyId, status])
  @@index([companyId, tags])
  @@index([useCount])
}

model SequenceStep {
  id          String     @id @default(cuid())
  sequenceId  String

  sortOrder   Int        @default(0)
  delayHours  Int        @default(24)
  action      String     @default("send_message")

  // Action-specific fields
  message     String?    @db.Text
  templateId  String?
  subject     String?
  tagName     String?
  webhookUrl  String?
  condition   String?    @db.Text
  metadata    Json       @default("{}")

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  sequence    Sequence   @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  template    Template?  @relation(fields: [templateId], references: [id])

  @@index([sequenceId, sortOrder])
}

model SequenceEnrollment {
  id            String            @id @default(cuid())
  sequenceId    String
  contactId     String
  companyId     String

  currentStep   Int               @default(0)
  status        EnrollmentStatus  @default(ACTIVE)

  // Timing
  enrolledAt    DateTime          @default(now())
  startedAt     DateTime?
  lastStepAt    DateTime?
  nextRunAt     DateTime?
  completedAt   DateTime?

  // Control
  pausedAt      DateTime?
  pausedReason  String?
  stoppedAt     DateTime?
  stoppedReason String?

  // Retry tracking
  retryCount    Int               @default(0)
  lastError     String?

  metadata      Json              @default("{}")

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  sequence      Sequence          @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contact       Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activities    SequenceEnrollmentActivity[]

  @@unique([sequenceId, contactId])
  @@index([companyId, status])
  @@index([nextRunAt])
  @@index([sequenceId, status])
}

model SequenceActivity {
  id          String                @id @default(cuid())
  sequenceId  String
  companyId   String
  type        SequenceActivityType
  actorType   String                // user | ai | system
  actorId     String?
  title       String
  body        String?
  metadata    Json                  @default("{}")
  createdAt   DateTime              @default(now())

  sequence    Sequence              @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId, createdAt])
  @@index([companyId, type])
}

model SequenceEnrollmentActivity {
  id            String              @id @default(cuid())
  enrollmentId  String
  companyId     String
  type          EnrollmentActivityType
  actorType     String              // user | ai | system | worker
  actorId       String?
  title         String
  body          String?
  metadata      Json                @default("{}")
  createdAt     DateTime            @default(now())

  enrollment    SequenceEnrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId, createdAt])
  @@index([companyId, type])
}

model CallLog {
  id        String   @id @default(cuid())
  companyId String
