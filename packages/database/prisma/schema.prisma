enum PaymentActivityType {
  CREATED
  LINK_GENERATED
  SENT_TO_CUSTOMER
  VIEWED_BY_CUSTOMER
  PAID
  FAILED
  REFUNDED
  REFUND_INITIATED
  REFUND_FAILED
  CANCELLED
  EXPIRED
  MANUAL_RECORDED
  WEBHOOK_RECEIVED
  FIELD_UPDATED
  NOTE_ADDED
  LINKED_TO_INVOICE
  LINKED_TO_DEAL
  ERROR
}

model Payment {
  id             String          @id @default(cuid())
  companyId      String
  contactId      String?
  dealId         String?
  /// Link to an Invoice for reconciliation. When a payment webhook fires
  /// and this is set, InvoicesService.recordPayment is called to bump the
  /// invoice's amountPaid and transition status when fully paid.
  invoiceId      String?
  provider       PaymentProvider
  externalId     String?
  linkUrl        String?
  /// Gateway-specific refund id returned by the provider when a refund succeeds.
  refundId       String?
  /// Amount actually refunded (minor units). May be less than total for partial refunds.
  refundedAmount Int             @default(0)
  refundReason   String?
  /// Payment method used — card, upi, netbanking, cash, bank_transfer, etc.
  /// For manual (provider=NONE) payments this is filled by the admin.
  method         String?
  amount         Int
  currency       String          @default("INR")
  description    String?
  notes          String?
  tags           String[]        @default([])
  status         PaymentStatus   @default(PENDING)
  paidAt         DateTime?
  refundedAt     DateTime?
  webhookPayload Json?
  idempotencyKey String          @unique
  createdByUserId String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  company    Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact    Contact?           @relation(fields: [contactId], references: [id])
  deal       Deal?              @relation(fields: [dealId], references: [id])
  activities PaymentActivity[]

  @@index([companyId])
  @@index([externalId])
  @@index([status])
  @@index([idempotencyKey])
  @@index([invoiceId])
  @@index([companyId, status])
  @@index([companyId, createdAt])
}

model PaymentActivity {
  id        String              @id @default(cuid())
  paymentId String
  companyId String
  type      PaymentActivityType
  actorType String              // "user" | "ai" | "system" | "worker" | "webhook"
  actorId   String?
  title     String
  body      String?
  metadata  Json                @default("{}")
  createdAt DateTime            @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@index([companyId, type, createdAt])
}

// ─── BROADCAST ────────────────────────────────────────────────────────────────

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  CANCELLED
  PAUSED
  FAILED
}

enum BroadcastRecipientStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
  SKIPPED
}

enum BroadcastActivityType {
  CREATED
  UPDATED
  AUDIENCE_CHANGED
  SCHEDULED
  STARTED
  PAUSED
  RESUMED
  CANCELLED
  COMPLETED
  FAILED
  RECIPIENT_SENT
  RECIPIENT_FAILED
  RECIPIENT_DELIVERED
  RECIPIENT_READ
  RETRY_FAILED
  CUSTOM
}

model Broadcast {
  id               String          @id @default(cuid())
  companyId        String
  name             String
  message          String
  mediaUrl         String?
  mediaType        String?
  mediaCaption     String?
  templateName     String?
  variables        Json            @default("{}")
  audienceFilter   Json?
  // Legacy raw audience inputs (kept for backwards compat with the old worker)
  targetTags       String[]        @default([])
  targetContactIds String[]        @default([])
  status           BroadcastStatus @default(DRAFT)
  throttleMs       Int             @default(2000)
  scheduledAt      DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  totalCount       Int             @default(0) // legacy alias for totalRecipients
  totalRecipients  Int             @default(0)
  sentCount        Int             @default(0)
  failedCount      Int             @default(0)
  deliveredCount   Int             @default(0)
  readCount        Int             @default(0)
  skippedCount     Int             @default(0)
  errorMessage     String?
  createdById      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  company    Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy  User?                @relation("BroadcastCreatedBy", fields: [createdById], references: [id])
  recipients BroadcastRecipient[]
  activities BroadcastActivity[]

  @@index([companyId])
  @@index([scheduledAt])
  @@index([companyId, status])
  @@index([scheduledAt, status])
  @@index([companyId, createdAt])
}

model BroadcastRecipient {
  id                String                   @id @default(cuid())
  broadcastId       String
  companyId         String
  contactId         String
  toPhone           String
  status            BroadcastRecipientStatus @default(QUEUED)
  /// Rendered, personalized message body for THIS recipient. Stored so retries
  /// don't re-render and the audit shows the exact text sent.
  renderedText      String
  mediaUrl          String?
  whatsappMessageId String?
  errorMessage      String?
  queuedAt          DateTime                 @default(now())
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  failedAt          DateTime?

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id])

  @@unique([broadcastId, contactId])
  @@index([broadcastId, status])
  @@index([companyId, contactId])
}

model BroadcastActivity {
  id          String                @id @default(cuid())
  broadcastId String
  companyId   String
  type        BroadcastActivityType
  actorType   String
  actorId     String?
  title       String
  body        String?
  metadata    Json                  @default("{}")
  createdAt   DateTime              @default(now())

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@index([broadcastId, createdAt])
  @@index([companyId, type])
}

