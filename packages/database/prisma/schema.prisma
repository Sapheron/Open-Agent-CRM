}

enum SequenceActivityType {
  CREATED
  UPDATED
  ACTIVATED
  PAUSED
  ARCHIVED
  DELETED
  STEPS_CHANGED
  ENROLLMENT_ADDED
  ENROLLMENT_REMOVED
