generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  AGENT
}

enum ConversationStatus {
  OPEN
  AI_HANDLING
  WAITING_HUMAN
  HUMAN_HANDLING
  RESOLVED
  CLOSED
  SPAM
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  LOCATION
  CONTACT
  TEMPLATE
  INTERACTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATING
  WON
  LOST
  DISQUALIFIED
}

enum LeadSource {
  WHATSAPP
  WEBSITE
  REFERRAL
  INBOUND_EMAIL
  OUTBOUND
  CAMPAIGN
  FORM
  IMPORT
  AI_CHAT
  MANUAL
  META_ADS
  WEBHOOK
  OTHER
}

enum LeadIntegrationProvider {
  META_ADS
  CUSTOM_WEBHOOK
}

enum LeadIntegrationStatus {
  ACTIVE
  PAUSED
  ERROR
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LeadActivityType {
  CREATED
  STATUS_CHANGED
  ASSIGNED
  UNASSIGNED
  SCORED
  NOTE_ADDED
  TAG_ADDED
  TAG_REMOVED
  CONTACTED
  RESPONDED
  MEETING_BOOKED
  PROPOSAL_SENT
  CONVERTED
  WON
  LOST
  DISQUALIFIED
  FIELD_UPDATED
  CUSTOM
}

enum DealStage {
  LEAD_IN
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum DealSource {
  LEAD_CONVERSION
  WHATSAPP
  MANUAL
  AI_CHAT
  REFERRAL
  CAMPAIGN
  WEBSITE
  IMPORT
  OTHER
}

enum DealPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DealLossReason {
  PRICE
  COMPETITOR
  TIMING
  NO_BUDGET
  NO_DECISION
  WRONG_FIT
  GHOSTED
  OTHER
}

enum DealActivityType {
  CREATED
  STAGE_CHANGED
  ASSIGNED
  UNASSIGNED
  VALUE_UPDATED
  PROBABILITY_UPDATED
  NOTE_ADDED
  TAG_ADDED
  TAG_REMOVED
  CONTACTED
  RESPONDED
  PROPOSAL_SENT
  MEETING_BOOKED
  LINE_ITEM_ADDED
  LINE_ITEM_REMOVED
  PAYMENT_RECEIVED
  WON
  LOST
  REOPENED
  FIELD_UPDATED
  CUSTOM
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskSource {
  MANUAL
  AI_CHAT
  WHATSAPP
  RECURRING
  AUTO_FOLLOW_UP
  IMPORT
  OTHER
}

enum TaskActivityType {
  CREATED
  STATUS_CHANGED
  ASSIGNED
  UNASSIGNED
  PRIORITY_CHANGED
  DUE_DATE_CHANGED
  TITLE_CHANGED
  DESCRIPTION_CHANGED
  COMMENT_ADDED
  SUBTASK_ADDED
  SUBTASK_COMPLETED
  SUBTASK_REMOVED
  WATCHER_ADDED
  WATCHER_REMOVED
  TIME_LOGGED
  RESCHEDULED
  REMINDER_SENT
  RECURRENCE_TRIGGERED
  COMPLETED
  CANCELLED
  REOPENED
  FIELD_UPDATED
  CUSTOM
}

enum TaskRecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM_DAYS
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
}

enum AiProvider {
  GEMINI
  OPENAI
  ANTHROPIC
  GROQ
  DEEPSEEK
  XAI
  MISTRAL
  TOGETHER
  MOONSHOT
  GLM
  QWEN
  STEPFUN
  OLLAMA
  OPENROUTER
  CUSTOM
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
  CASHFREE
  PHONEPE
  PAYU
  NONE
}

enum WaAccountStatus {
  DISCONNECTED
  QR_PENDING
  CONNECTING
  CONNECTED
  BANNED
  ERROR
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  AI_TOOL_CALL
  AI_REPLY
  PAYMENT_CREATED
  PAYMENT_RECEIVED
  WA_SESSION_START
  WA_SESSION_END
  USER_LOGIN
  USER_LOGOUT
  SETTINGS_CHANGE
}

// ─── COMPANY ──────────────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  email     String?
  phone     String?
  website   String?
  logoUrl   String?
  publicUrl String? // Public URL for webhooks/integrations (e.g., https://yourdomain.com)
  timezone  String   @default("UTC")
  isActive  Boolean  @default(true)
  setupDone Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  whatsappAccounts WhatsAppAccount[]
  contacts         Contact[]
  conversations    Conversation[]
  leads            Lead[]
  deals            Deal[]
  tasks            Task[]
  payments         Payment[]
  broadcasts       Broadcast[]
  auditLogs        AuditLog[]
  aiConfig         AiConfig?
  paymentConfig    PaymentConfig?
  webhookEndpoints WebhookEndpoint[]

  @@index([slug])
  @@index([isActive])
}

// ─── USER ─────────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  companyId        String
  email            String
  passwordHash     String
  firstName        String
  lastName         String
  avatarUrl        String?
  role             UserRole  @default(AGENT)
  isActive         Boolean   @default(true)
  refreshTokenHash String?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company           Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedConvs     Conversation[] @relation("AssignedAgent")
  assignedLeads     Lead[]         @relation("AssignedAgent")
  assignedDeals     Deal[]         @relation("AssignedAgent")
  assignedTasks     Task[]         @relation("AssignedAgent")
  createdTasks      Task[]         @relation("CreatedBy")
  createdBroadcasts Broadcast[]    @relation("BroadcastCreatedBy")
  auditLogs         AuditLog[]

  @@unique([companyId, email])
  @@index([companyId])
  @@index([email])
}

// ─── WHATSAPP ACCOUNT ─────────────────────────────────────────────────────────

model WhatsAppAccount {
  id                String          @id @default(cuid())
  companyId         String
  phoneNumber       String
  displayName       String?
  status            WaAccountStatus @default(DISCONNECTED)
  provider          String          @default("baileys")
  accessTokenEnc    String?
  phoneNumberId     String?
  sessionDataEnc    Bytes?
  qrCode            String?
  warmupStage       Int             @default(0)
  warmupStartedAt   DateTime?
  dailyMessageLimit Int             @default(50)
  messagesSentToday Int             @default(0)
  lastResetAt       DateTime?
  consecutiveErrors Int             @default(0)
  lastErrorAt       DateTime?
  lastConnectedAt   DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  messages      Message[]

  @@unique([companyId, phoneNumber])
  @@index([companyId])
  @@index([status])
}

// ─── CONTACT ──────────────────────────────────────────────────────────────────

model Contact {
  id             String    @id @default(cuid())
  companyId      String
  phoneNumber    String
  displayName    String?
  firstName      String?
  lastName       String?
  email          String?
  avatarUrl      String?
  tags           String[]
  customFields   Json      @default("{}")
  notes          String?
  lifecycleStage String    @default("SUBSCRIBER")
  score          Int       @default(0)
  companyName    String?
  jobTitle       String?
  address        String?
  socialLinks    Json      @default("{}")
  referredById   String?
  isBlocked      Boolean   @default(false)
  optedOut       Boolean   @default(false)
  optedOutAt     DateTime?
  lastSeenAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  referredBy          Contact?             @relation("ContactReferrals", fields: [referredById], references: [id])
  referrals           Contact[]            @relation("ContactReferrals")
  conversations       Conversation[]
  leads               Lead[]
  deals               Deal[]
  tasks               Task[]
  payments            Payment[]
  contactNotes        ContactNote[]
  broadcastRecipients BroadcastRecipient[]

  @@unique([companyId, phoneNumber])
  @@index([companyId])
  @@index([phoneNumber])
  @@index([companyId, deletedAt])
  @@index([tags])
  @@index([companyId, lifecycleStage])
  @@index([companyId, score])
}

// ─── CONVERSATION ─────────────────────────────────────────────────────────────

model Conversation {
  id                String             @id @default(cuid())
  companyId         String
  contactId         String
  whatsappAccountId String
  assignedAgentId   String?
  status            ConversationStatus @default(OPEN)
  aiEnabled         Boolean            @default(true)
  unreadCount       Int                @default(0)
  lastMessageAt     DateTime?
  lastMessageText   String?
  resolvedAt        DateTime?
  metadata          Json               @default("{}")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact         Contact         @relation(fields: [contactId], references: [id])
  whatsappAccount WhatsAppAccount @relation(fields: [whatsappAccountId], references: [id])
  assignedAgent   User?           @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  messages        Message[]
  aiContextCache  AiContextCache?

  @@index([companyId])
  @@index([contactId])
  @@index([status])
  @@index([companyId, status])
  @@index([lastMessageAt])
}

// ─── MESSAGE ──────────────────────────────────────────────────────────────────

model Message {
  id                String           @id @default(cuid())
  companyId         String
  conversationId    String
  whatsappAccountId String
  whatsappMessageId String?
  idempotencyKey    String?          @unique
  direction         MessageDirection
  type              MessageType      @default(TEXT)
  status            MessageStatus    @default(PENDING)
  body              String?
  mediaUrl          String?
  mediaType         String?
  mediaSizeBytes    Int?
  mediaCaption      String?
  latitude          Float?
  longitude         Float?
  replyToMessageId  String?
  isAiGenerated     Boolean          @default(false)
  aiProvider        String?
  aiModel           String?
  aiTokensUsed      Int?
  aiLatencyMs       Int?
  errorMessage      String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  failedAt          DateTime?
  createdAt         DateTime         @default(now())

  conversation    Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsAppAccount @relation(fields: [whatsappAccountId], references: [id])
  replyTo         Message?        @relation("ReplyThread", fields: [replyToMessageId], references: [id])
  replies         Message[]       @relation("ReplyThread")

  @@index([conversationId])
  @@index([whatsappMessageId])
  @@index([idempotencyKey])
  @@index([companyId, createdAt])
  @@index([direction, status])
}

// ─── LEAD ─────────────────────────────────────────────────────────────────────

model Lead {
  id                 String       @id @default(cuid())
  companyId          String
  contactId          String
  assignedAgentId    String?
  title              String
  status             LeadStatus   @default(NEW)
  source             LeadSource   @default(MANUAL)
  priority           LeadPriority @default(MEDIUM)
  score              Int          @default(0)
  probability        Int          @default(20) // 0-100
  estimatedValue     Float?
  currency           String       @default("INR")
  tags               String[]     @default([])
  notes              String?
  customFields       Json         @default("{}")
  expectedCloseAt    DateTime?
  nextActionAt       DateTime?
  nextActionNote     String?
  qualifiedAt        DateTime?
  disqualifiedAt     DateTime?
  disqualifiedReason String?
  lostReason         String?
  wonAt              DateTime?
  lostAt             DateTime?
  slaFirstResponseAt DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?

  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact       Contact          @relation(fields: [contactId], references: [id])
  assignedAgent User?            @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  deals         Deal[]
  tasks         Task[]
  activities    LeadActivity[]
  scoreEvents   LeadScoreEvent[]

  @@index([companyId])
  @@index([contactId])
  @@index([status])
  @@index([companyId, status])
  @@index([companyId, source])
  @@index([companyId, priority])
  @@index([companyId, assignedAgentId])
  @@index([companyId, nextActionAt])
}

model LeadActivity {
  id        String           @id @default(cuid())
  leadId    String
  companyId String
  type      LeadActivityType
  actorType String // user | ai | system | whatsapp
  actorId   String? // userId if actor is a user
  title     String
  body      String?
  metadata  Json             @default("{}")
  createdAt DateTime         @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([companyId, type])
}

model LeadScoreEvent {
  id        String   @id @default(cuid())
  leadId    String
  companyId String
  delta     Int
  newScore  Int
  reason    String
  source    String // auto | manual | ai | rule:<name>
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}

// ─── LEAD INTAKE INTEGRATIONS (Meta Ads + custom webhooks) ──────────────────

model LeadIntakeIntegration {
  id        String                  @id @default(cuid())
  companyId String
  provider  LeadIntegrationProvider
  name      String
  status    LeadIntegrationStatus   @default(ACTIVE)

  // Meta-specific fields. AppSecret + PageAccessToken are encrypted at rest
  // using the existing `encrypt`/`decrypt` helpers from @wacrm/shared.
  metaPageId             String?
  metaPageName           String?
  metaAppSecretEnc       String?
  metaVerifyToken        String?
  metaPageAccessTokenEnc String?

  // Stats
  lastEventAt DateTime?
  lastError   String?
  totalLeads  Int       @default(0)

  // Defaults applied to every lead created via this integration
  defaultTags     String[]     @default([])
  defaultPriority LeadPriority @default(MEDIUM)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([companyId, provider])
}

// ─── DEAL ─────────────────────────────────────────────────────────────────────

model Deal {
  id              String          @id @default(cuid())
  companyId       String
  contactId       String
  leadId          String?
  assignedAgentId String?
  title           String
  stage           DealStage       @default(LEAD_IN)
  source          DealSource      @default(MANUAL)
  priority        DealPriority    @default(MEDIUM)
  value           Float
  currency        String          @default("INR")
  probability     Int             @default(20)
  weightedValue   Float? // value * probability/100, maintained by service
  tags            String[]        @default([])
  expectedCloseAt DateTime?
  nextActionAt    DateTime?
  nextActionNote  String?
  qualifiedAt     DateTime?
  proposalSentAt  DateTime?
  wonAt           DateTime?
  lostAt          DateTime?
  lostReason      String? // legacy free-text reason
  lostReasonCode  DealLossReason? // taxonomic reason for analytics
  salesCycleDays  Int? // days from createdAt → wonAt/lostAt
  lastTouchedAt   DateTime? // updated by WhatsApp ingest hook
  notes           String?
  customFields    Json            @default("{}")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact       Contact        @relation(fields: [contactId], references: [id])
  lead          Lead?          @relation(fields: [leadId], references: [id])
  assignedAgent User?          @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  payments      Payment[]
  tasks         Task[]
  activities    DealActivity[]
  lineItems     DealLineItem[]

  @@index([companyId])
  @@index([contactId])
  @@index([stage])
  @@index([companyId, stage])
  @@index([companyId, source])
  @@index([companyId, priority])
  @@index([companyId, assignedAgentId])
  @@index([companyId, nextActionAt])
  @@index([companyId, lastTouchedAt])
}

model DealActivity {
  id        String           @id @default(cuid())
  dealId    String
  companyId String
  type      DealActivityType
  actorType String // user | ai | system | whatsapp | payment
  actorId   String?
  title     String
  body      String?
  metadata  Json             @default("{}")
  createdAt DateTime         @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, createdAt])
  @@index([companyId, type])
}

model DealLineItem {
  id          String   @id @default(cuid())
  dealId      String
  companyId   String
  productId   String?
  name        String
  description String?
  quantity    Float    @default(1)
  unitPrice   Float
  discount    Float    @default(0) // percent
  taxRate     Float    @default(0) // percent
  total       Float
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deal    Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([dealId])
  @@index([companyId])
}

// ─── TASK ─────────────────────────────────────────────────────────────────────

model Task {
  id              String       @id @default(cuid())
  companyId       String
  contactId       String?
  dealId          String?
  leadId          String?
  parentTaskId    String? // for subtasks (self-relation below)
  recurrenceId    String? // FK to TaskRecurrence if part of a recurring series
  assignedAgentId String?
  createdById     String?
  title           String
  description     String?
  status          TaskStatus   @default(TODO)
  priority        TaskPriority @default(MEDIUM)
  source          TaskSource   @default(MANUAL)
  tags            String[]     @default([])
  position        Int          @default(0)
  estimatedHours  Float?
  actualHours     Float?       @default(0)
  dueAt           DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  cleanupAfter    DateTime? // OpenClaw-style TTL — set when task reaches DONE/CANCELLED
  reminderOffsets Int[]        @default([30]) // minutes before dueAt to fire each reminder
  remindersSent   DateTime[]   @default([]) // history of reminder fire times
  reminderSentAt  DateTime? // legacy column kept for backwards compat with reminder.processor.ts
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact       Contact?        @relation(fields: [contactId], references: [id])
  deal          Deal?           @relation(fields: [dealId], references: [id])
  lead          Lead?           @relation(fields: [leadId], references: [id])
  recurrence    TaskRecurrence? @relation(fields: [recurrenceId], references: [id])
  assignedAgent User?           @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  createdBy     User?           @relation("CreatedBy", fields: [createdById], references: [id])
  parent        Task?           @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks      Task[]          @relation("TaskSubtasks")
  activities    TaskActivity[]
  comments      TaskComment[]
  watchers      TaskWatcher[]

  @@index([companyId])
  @@index([assignedAgentId])
  @@index([dueAt])
  @@index([status])
  @@index([companyId, source])
  @@index([companyId, parentTaskId])
  @@index([companyId, recurrenceId])
  @@index([companyId, cleanupAfter])
  @@index([leadId])
}

model TaskActivity {
  id        String           @id @default(cuid())
  taskId    String
  companyId String
  type      TaskActivityType
  actorType String // user | ai | system | whatsapp | recurrence
  actorId   String?
  title     String
  body      String?
  metadata  Json             @default("{}")
  createdAt DateTime         @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([companyId, type])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  companyId String
  authorId  String? // null = AI / system
  body      String
  mentions  String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model TaskWatcher {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  companyId String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
}

model TaskRecurrence {
  id                      String                  @id @default(cuid())
  companyId               String
  templateTitle           String
  templateBody            String?
  templatePriority        TaskPriority            @default(MEDIUM)
  templateAssignedAgentId String?
  frequency               TaskRecurrenceFrequency
  intervalDays            Int? // for CUSTOM_DAYS
  daysOfWeek              Int[]                   @default([]) // for WEEKLY: 0=Sun..6=Sat
  dayOfMonth              Int? // for MONTHLY
  startsAt                DateTime
  endsAt                  DateTime?
  nextRunAt               DateTime
  lastRunAt               DateTime?
  totalGenerated          Int                     @default(0)
  isActive                Boolean                 @default(true)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  tasks Task[]

  @@index([companyId])
  @@index([nextRunAt, isActive])
}

// ─── AI CONFIG ────────────────────────────────────────────────────────────────

model AiConfig {
  id                 String     @id @default(cuid())
  companyId          String     @unique
  provider           AiProvider @default(GEMINI)
  model              String     @default("gemini-2.0-flash")
  apiKeyEncrypted    String?
  baseUrl            String?
  systemPrompt       String     @default("You are a helpful sales assistant. Help the customer and capture their information.")
  tone               String     @default("professional")
  maxTokens          Int        @default(1024)
  temperature        Float      @default(0.7)
  autoReplyEnabled   Boolean    @default(true)
  toolCallingEnabled Boolean    @default(true)
  testStatus         String?
  testError          String?
  updatedAt          DateTime   @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AiContextCache {
  id             String   @id @default(cuid())
  conversationId String   @unique
  messages       Json
  tokenCount     Int
  pruneCount     Int      @default(0)
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ─── PAYMENT ──────────────────────────────────────────────────────────────────

model PaymentConfig {
  id              String          @id @default(cuid())
  companyId       String          @unique
  provider        PaymentProvider @default(NONE)
  keyEncrypted    String?
  secretEncrypted String?
  webhookSecret   String?
  currency        String          @default("INR")
  testMode        Boolean         @default(true)
  updatedAt       DateTime        @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Payment {
  id             String          @id @default(cuid())
  companyId      String
  contactId      String?
  dealId         String?
  provider       PaymentProvider
  externalId     String?
  linkUrl        String?
  amount         Int
  currency       String          @default("INR")
  description    String?
  status         PaymentStatus   @default(PENDING)
  paidAt         DateTime?
  refundedAt     DateTime?
  webhookPayload Json?
  idempotencyKey String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id])
  deal    Deal?    @relation(fields: [dealId], references: [id])

  @@index([companyId])
  @@index([externalId])
  @@index([status])
  @@index([idempotencyKey])
}

// ─── BROADCAST ────────────────────────────────────────────────────────────────

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  CANCELLED
  PAUSED
  FAILED
}

enum BroadcastRecipientStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
  SKIPPED
}

enum BroadcastActivityType {
  CREATED
  UPDATED
  AUDIENCE_CHANGED
  SCHEDULED
  STARTED
  PAUSED
  RESUMED
  CANCELLED
  COMPLETED
  FAILED
  RECIPIENT_SENT
  RECIPIENT_FAILED
  RECIPIENT_DELIVERED
  RECIPIENT_READ
  RETRY_FAILED
  CUSTOM
}

model Broadcast {
  id               String          @id @default(cuid())
  companyId        String
  name             String
  message          String
  mediaUrl         String?
  mediaType        String?
  mediaCaption     String?
  templateName     String?
  variables        Json            @default("{}")
  audienceFilter   Json?
  // Legacy raw audience inputs (kept for backwards compat with the old worker)
  targetTags       String[]        @default([])
  targetContactIds String[]        @default([])
  status           BroadcastStatus @default(DRAFT)
  throttleMs       Int             @default(2000)
  scheduledAt      DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  totalCount       Int             @default(0) // legacy alias for totalRecipients
  totalRecipients  Int             @default(0)
  sentCount        Int             @default(0)
  failedCount      Int             @default(0)
  deliveredCount   Int             @default(0)
  readCount        Int             @default(0)
  skippedCount     Int             @default(0)
  errorMessage     String?
  createdById      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  company    Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy  User?                @relation("BroadcastCreatedBy", fields: [createdById], references: [id])
  recipients BroadcastRecipient[]
  activities BroadcastActivity[]

  @@index([companyId])
  @@index([scheduledAt])
  @@index([companyId, status])
  @@index([scheduledAt, status])
  @@index([companyId, createdAt])
}

model BroadcastRecipient {
  id                String                   @id @default(cuid())
  broadcastId       String
  companyId         String
  contactId         String
  toPhone           String
  status            BroadcastRecipientStatus @default(QUEUED)
  /// Rendered, personalized message body for THIS recipient. Stored so retries
  /// don't re-render and the audit shows the exact text sent.
  renderedText      String
  mediaUrl          String?
  whatsappMessageId String?
  errorMessage      String?
  queuedAt          DateTime                 @default(now())
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  failedAt          DateTime?

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id])

  @@unique([broadcastId, contactId])
  @@index([broadcastId, status])
  @@index([companyId, contactId])
}

model BroadcastActivity {
  id          String                @id @default(cuid())
  broadcastId String
  companyId   String
  type        BroadcastActivityType
  actorType   String
  actorId     String?
  title       String
  body        String?
  metadata    Json                  @default("{}")
  createdAt   DateTime              @default(now())

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@index([broadcastId, createdAt])
  @@index([companyId, type])
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  companyId  String
  userId     String?
  action     AuditAction
  entityType String?
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─── WEBHOOK ENDPOINT ─────────────────────────────────────────────────────────

model WebhookEndpoint {
